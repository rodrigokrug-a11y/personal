---
export const prerender = false;
import Layout from "../../layouts/Layout.astro";
import Icon from "../../components/Icon.astro";
import { readFile } from "node:fs/promises";
import { join } from "node:path";

// Lê os prompts da fonte única (PROMPT-ARTIGO.md) e extrai os blocos de código.
// Divide pelas linhas que são exatamente uma cerca de código (```), e pega os
// blocos de índice ímpar (entre abertura e fechamento). Isso é robusto mesmo
// quando o texto do prompt menciona crases.
let blocks: string[] = [];
try {
  const md = await readFile(join(process.cwd(), "PROMPT-ARTIGO.md"), "utf8");
  const parts = md.split(/^```.*$/m);
  // parts[1], parts[3], ... são os conteúdos dentro das cercas.
  blocks = parts.filter((_, i) => i % 2 === 1).map((s) => s.trim());
} catch {
  blocks = [];
}

// Metadados de cada card. Casa com a ordem dos blocos em PROMPT-ARTIGO.md.
const meta = [
  {
    titulo: "Artigo de blog",
    desc: "Gera um artigo de autoridade (insights) para o blog.",
    icon: "upload" as const,
  },
  {
    titulo: "Estudo de caso (projeto com código)",
    desc: "A IA analisa um projeto digital seu e escreve a página comercial.",
    icon: "product" as const,
  },
  {
    titulo: "Projeto descrito por você",
    desc: "Para projetos sem código: você descreve, a IA monta a estrutura.",
    icon: "ops" as const,
  },
];

const prompts = blocks.map((texto, i) => ({
  titulo: meta[i]?.titulo || `Prompt ${i + 1}`,
  desc: meta[i]?.desc || "",
  icon: meta[i]?.icon || ("product" as const),
  texto,
}));
---

<Layout lang="pt" title="Prompts" description="Prompts para gerar conteúdo">
  <main class="mx-auto max-w-3xl px-5 py-12">
    <a
      href="/admin"
      class="mb-6 inline-flex items-center gap-1.5 text-sm font-medium text-slate-500 transition hover:text-violet-600"
    >
      <Icon name="arrow-up-right" class="h-4 w-4 rotate-[225deg]" />
      Voltar ao admin
    </a>

    <h1 class="font-display text-2xl font-bold tracking-tight text-slate-900">
      Prompts para gerar conteúdo
    </h1>
    <p class="mt-2 mb-8 text-sm leading-relaxed text-slate-600">
      Copie um dos prompts, cole no Claude (na pasta do projeto que quer
      divulgar) e ele gera o JSON pronto. Depois é só colar em
      <a href="/importar" class="text-violet-600 underline">Importar</a>.
    </p>

    <div class="space-y-8">
      {
        prompts.map((p) => (
          <section class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
            <div class="mb-3 flex items-center justify-between gap-3">
              <div class="flex items-center gap-2.5">
                <span class="bg-brand grid h-9 w-9 place-items-center rounded-xl text-white shadow-sm">
                  <Icon name={p.icon} class="h-4 w-4" />
                </span>
                <div>
                  <h2 class="font-display text-base font-bold text-slate-900">{p.titulo}</h2>
                  <p class="text-xs text-slate-500">{p.desc}</p>
                </div>
              </div>
              <button
                type="button"
                class="copy-btn bg-brand inline-flex shrink-0 items-center gap-1.5 rounded-lg px-3.5 py-2 text-xs font-semibold text-white shadow-sm transition hover:opacity-90"
              >
                <Icon name="upload" class="h-3.5 w-3.5" />
                <span class="copy-label">Copiar</span>
              </button>
            </div>
            <pre class="prompt-text max-h-72 overflow-auto rounded-xl bg-slate-900 p-4 text-xs leading-relaxed text-slate-100"><code>{p.texto}</code></pre>
          </section>
        ))
      }
    </div>

    {
      blocks.length === 0 && (
        <p class="mt-6 rounded-xl border border-amber-200 bg-amber-50 p-4 text-sm text-amber-800">
          Não consegui carregar os prompts do arquivo. Eles estão em
          <code>PROMPT-ARTIGO.md</code> no projeto.
        </p>
      )
    }
  </main>
</Layout>

<script>
  document.querySelectorAll<HTMLButtonElement>(".copy-btn").forEach((btn) => {
    btn.addEventListener("click", async () => {
      const section = btn.closest("section");
      const text = section?.querySelector(".prompt-text code")?.textContent || "";
      const label = btn.querySelector(".copy-label");
      try {
        await navigator.clipboard.writeText(text);
        if (label) label.textContent = "Copiado!";
      } catch {
        // fallback: seleciona o texto
        const range = document.createRange();
        const code = section?.querySelector(".prompt-text code");
        if (code) {
          range.selectNodeContents(code);
          const sel = window.getSelection();
          sel?.removeAllRanges();
          sel?.addRange(range);
        }
        if (label) label.textContent = "Selecionado — Ctrl+C";
      }
      setTimeout(() => {
        if (label) label.textContent = "Copiar";
      }, 2500);
    });
  });
</script>
