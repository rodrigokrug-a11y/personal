---
import "../styles/global.css";
import { personal, socials } from "../data/site";
import type { Lang } from "../i18n/ui";

interface Props {
  lang: Lang;
  title: string;
  description: string;
  /** Imagem para compartilhamento (caminho absoluto começando com /). */
  image?: string;
  /** "website" (padrão) ou "article" para posts/projetos. */
  ogType?: "website" | "article";
  /** true em páginas privadas (admin, importar) — fora do Google. */
  noindex?: boolean;
  /** Caminho da mesma página no outro idioma, para hreflang. */
  altPath?: string;
  /** JSON-LD extra (ex.: BreadcrumbList, CreativeWork) por página. */
  jsonLd?: object | object[];
}

const {
  lang,
  title,
  description,
  image,
  ogType = "website",
  noindex = false,
  altPath,
  jsonLd,
} = Astro.props;

const siteUrl = Astro.site ?? new URL("https://rodrigokrug.com.br");
// URL canônica = a própria página (sem query), no domínio oficial.
const canonical = new URL(Astro.url.pathname, siteUrl).href;
const ogImage = new URL(image ?? "/images/og.png", siteUrl).href;
const usingDefaultOg = !image; // og.png padrão tem dimensões conhecidas (1200x630)
const isPt = lang === "pt";

// --- hreflang: cluster recíproco e auto-referencial ---------------------------
// Normaliza para barra final (igual ao canonical) e calcula as duas versões.
const withSlash = (p: string) => (p.endsWith("/") ? p : p + "/");
const altUrl = altPath ? new URL(withSlash(altPath), siteUrl).href : undefined;
// URL desta página em PT (padrão) e em EN, derivadas de canonical + altPath.
const ptUrl = isPt ? canonical : altUrl;
const enUrl = isPt ? altUrl : canonical;

// Lista de blocos JSON-LD extras (BreadcrumbList, CreativeWork…).
const extraLd = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];

// JSON-LD: descreve o Rodrigo como pessoa/profissional para o Google.
const personLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: personal.name,
  // Mesma string exibida no site (Hero) — fonte única, sem divergência.
  jobTitle: personal.role[lang].trim(),
  description: personal.intro[lang],
  url: canonical,
  image: ogImage,
  email: `mailto:${personal.email}`,
  worksFor: { "@type": "Organization", name: "Loot Studios" },
  address: {
    "@type": "PostalAddress",
    addressLocality: "Belo Horizonte",
    addressRegion: "MG",
    addressCountry: "BR",
  },
  knowsAbout: isPt
    ? [
        "Operações",
        "Supply Chain",
        "Manufatura",
        "Gestão de Operações",
        "Consultoria",
        "Engenharia",
      ]
    : [
        "Operations",
        "Supply Chain",
        "Manufacturing",
        "Operations Management",
        "Consulting",
        "Engineering",
      ],
  sameAs: socials.map((s) => s.href).filter(Boolean),
};
---

<!doctype html>
<html lang={isPt ? "pt-BR" : "en"}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/favicon.png" />

    <!-- Tema (claro/escuro) aplicado ANTES de pintar, para evitar "flash". -->
    <script is:inline>
      (() => {
        try {
          const saved = localStorage.getItem("theme");
          const dark = saved
            ? saved === "dark"
            : window.matchMedia("(prefers-color-scheme: dark)").matches;
          if (dark) document.documentElement.classList.add("dark");
        } catch (e) {}
      })();
    </script>
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content={personal.name} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <!-- URL canônica -->
    <link rel="canonical" href={canonical} />

    <!-- Idiomas alternativos (hreflang): cluster recíproco, auto-referencial,
         x-default = versão PT (idioma padrão) DESTA página. -->
    {
      altPath && ptUrl && enUrl && (
        <>
          <link rel="alternate" hreflang="pt-BR" href={ptUrl} />
          <link rel="alternate" hreflang="en" href={enUrl} />
          <link rel="alternate" hreflang="x-default" href={ptUrl} />
        </>
      )
    }

    <!-- Open Graph / redes sociais -->
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:alt" content={title} />
    {
      usingDefaultOg && (
        <>
          <meta property="og:image:width" content="1200" />
          <meta property="og:image:height" content="630" />
        </>
      )
    }
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content={personal.name} />
    <meta property="og:locale" content={isPt ? "pt_BR" : "en_US"} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={title} />

    <!-- Dados estruturados (somente em páginas indexáveis) -->
    {
      !noindex && (
        <script
          type="application/ld+json"
          set:html={JSON.stringify(personLd)}
        />
      )
    }
    {
      !noindex &&
        extraLd.map((obj) => (
          <script type="application/ld+json" set:html={JSON.stringify(obj)} />
        ))
    }

    <!-- Fontes -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="bg-white text-slate-900 antialiased selection:text-slate-900">
    <slot />

    <!-- Revelação suave ao rolar a página -->
    <script>
      const reveals = document.querySelectorAll<HTMLElement>("[data-reveal]");
      if ("IntersectionObserver" in window && reveals.length) {
        const io = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                entry.target.classList.add("is-visible");
                io.unobserve(entry.target);
              }
            }
          },
          { threshold: 0.12, rootMargin: "0px 0px -40px 0px" },
        );
        reveals.forEach((el) => io.observe(el));
      } else {
        reveals.forEach((el) => el.classList.add("is-visible"));
      }
    </script>
  </body>
</html>
