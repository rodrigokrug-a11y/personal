---
import "../styles/global.css";
import { personal, socials } from "../data/site";
import type { Lang } from "../i18n/ui";

interface Props {
  lang: Lang;
  title: string;
  description: string;
  /** Imagem para compartilhamento (caminho absoluto começando com /). */
  image?: string;
  /** "website" (padrão) ou "article" para posts/projetos. */
  ogType?: "website" | "article";
  /** true em páginas privadas (admin, importar) — fora do Google. */
  noindex?: boolean;
  /** Caminho da mesma página no outro idioma, para hreflang. */
  altPath?: string;
}

const {
  lang,
  title,
  description,
  image,
  ogType = "website",
  noindex = false,
  altPath,
} = Astro.props;

const siteUrl = Astro.site ?? new URL("https://rodrigokrug.com.br");
// URL canônica = a própria página (sem query), no domínio oficial.
const canonical = new URL(Astro.url.pathname, siteUrl).href;
const ogImage = new URL(image ?? "/images/og.png", siteUrl).href;
const isPt = lang === "pt";

// JSON-LD: descreve o Rodrigo como pessoa/profissional para o Google.
const personLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: personal.name,
  jobTitle: isPt ? "Diretor de Operações & Supply Chain" : "Director of Operations & Supply Chain",
  description: personal.intro[lang],
  url: siteUrl.href,
  image: ogImage,
  email: `mailto:${personal.email}`,
  address: {
    "@type": "PostalAddress",
    addressLocality: "Belo Horizonte",
    addressRegion: "MG",
    addressCountry: "BR",
  },
  knowsAbout: isPt
    ? [
        "Operações",
        "Supply Chain",
        "Manufatura",
        "Gestão de Operações",
        "Consultoria",
        "Engenharia",
      ]
    : [
        "Operations",
        "Supply Chain",
        "Manufacturing",
        "Operations Management",
        "Consulting",
        "Engineering",
      ],
  sameAs: socials.map((s) => s.href).filter(Boolean),
};
---

<!doctype html>
<html lang={isPt ? "pt-BR" : "en"}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content={personal.name} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <!-- URL canônica -->
    <link rel="canonical" href={canonical} />

    <!-- Idiomas alternativos (hreflang) -->
    {
      altPath && (
        <>
          <link
            rel="alternate"
            hreflang={isPt ? "en" : "pt-BR"}
            href={new URL(altPath, siteUrl).href}
          />
          <link rel="alternate" hreflang="x-default" href={siteUrl.href} />
        </>
      )
    }

    <!-- Open Graph / redes sociais -->
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content={personal.name} />
    <meta property="og:locale" content={isPt ? "pt_BR" : "en_US"} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Dados estruturados (somente em páginas indexáveis) -->
    {
      !noindex && (
        <script
          type="application/ld+json"
          set:html={JSON.stringify(personLd)}
        />
      )
    }

    <!-- Fontes -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Space+Grotesk:wght@500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="bg-white text-slate-900 antialiased selection:text-slate-900">
    <slot />

    <!-- Revelação suave ao rolar a página -->
    <script>
      const reveals = document.querySelectorAll<HTMLElement>("[data-reveal]");
      if ("IntersectionObserver" in window && reveals.length) {
        const io = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                entry.target.classList.add("is-visible");
                io.unobserve(entry.target);
              }
            }
          },
          { threshold: 0.12, rootMargin: "0px 0px -40px 0px" },
        );
        reveals.forEach((el) => io.observe(el));
      } else {
        reveals.forEach((el) => el.classList.add("is-visible"));
      }
    </script>
  </body>
</html>
