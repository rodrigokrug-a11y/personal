---
import Layout from "../layouts/Layout.astro";
import Footer from "./Footer.astro";
import Icon from "./Icon.astro";
import { personal, type Project } from "../data/site";
import { renderMarkdown } from "../lib/markdown";
import { useTranslations, type Lang } from "../i18n/ui";

interface Props {
  project: Project;
  lang: Lang;
}
const { project, lang } = Astro.props;
const t = useTranslations(lang);

const homeHref = lang === "pt" ? "/" : "/en/";
const projectsHref = `${homeHref}#projetos`;
// URL da mesma página no outro idioma
const altHref =
  lang === "pt" ? `/en/projects/${project.slug}` : `/projetos/${project.slug}`;

const title = `${project.name} — ${personal.name}`;
const description = project.description[lang];
---

<Layout
  lang={lang}
  title={title}
  description={description}
  image={project.image}
  ogType="article"
  altPath={altHref}
>
  <!-- Cabeçalho simples (volta para a home) -->
  <header class="glass sticky top-0 z-50 border-b border-slate-200/60">
    <div class="mx-auto flex max-w-5xl items-center justify-between px-5 py-3.5">
      <a href={homeHref} class="flex items-center gap-2.5">
        <span class="bg-brand grid h-9 w-9 place-items-center rounded-xl text-sm font-bold text-white shadow-sm">
          {personal.initials}
        </span>
        <span class="font-display font-bold tracking-tight">{personal.name}</span>
      </a>
      <div class="flex items-center gap-4">
        <a
          href={altHref}
          class="rounded-full border border-slate-200 px-3 py-1.5 text-xs font-semibold text-slate-600 transition hover:border-violet-300 hover:text-violet-600"
        >
          {t("lang.switch")}
        </a>
        <a
          href={projectsHref}
          class="inline-flex items-center gap-1.5 text-sm font-semibold text-slate-700 transition hover:text-violet-600"
        >
          <Icon name="arrow-up-right" class="h-4 w-4 rotate-[225deg]" />
          {t("projects.back")}
        </a>
      </div>
    </div>
  </header>

  <main class="mx-auto max-w-3xl px-5 pb-24">
    <!-- Capa -->
    <div
      class="relative mt-8 flex aspect-[16/7] items-end overflow-hidden rounded-3xl p-6 sm:p-8"
      style={`background-image:${project.gradient}`}
    >
      {
        project.image && (
          <img
            src={project.image}
            alt={project.name}
            class="absolute inset-0 h-full w-full object-cover"
          />
        )
      }
    </div>

    <!-- Título e meta -->
    <div class="mt-8">
      <div class="flex flex-wrap items-center gap-3 text-sm text-slate-500">
        <span class="font-medium text-violet-600">{project.year}</span>
        {project.featured && <span>· ★ {t("projects.featured")}</span>}
      </div>
      <h1 class="font-display mt-2 text-4xl font-bold tracking-tight text-slate-900 sm:text-5xl">
        {project.name}
      </h1>
      <p class="mt-3 text-lg text-slate-600">{project.tagline[lang]}</p>

      <p class="mt-4 text-sm text-slate-500">
        <span class="font-semibold uppercase tracking-wider text-slate-400"
          >{t("projects.role")}:</span
        >
        {project.role[lang]}
      </p>
    </div>

    <!-- Métricas -->
    {
      project.metrics.length > 0 && (
        <dl class="mt-8 grid grid-cols-2 gap-3 sm:grid-cols-3">
          {project.metrics.map((m) => (
            <div class="rounded-2xl border border-slate-200 bg-white px-4 py-3 shadow-sm">
              <dt class="font-display text-2xl font-bold text-gradient">{m.value}</dt>
              <dd class="mt-0.5 text-xs leading-tight text-slate-500">{m.label[lang]}</dd>
            </div>
          ))}
        </dl>
      )
    }

    <!-- Conteúdo rico (Markdown → títulos, listas, imagens, tabelas, links) -->
    <article class="richtext mt-12" set:html={renderMarkdown(project.body[lang])} />

    <!-- Tags + link externo -->
    <div class="mt-10 flex flex-wrap items-center gap-2">
      {
        project.tags.map((tag) => (
          <span class="rounded-full border border-slate-200 bg-white px-2.5 py-1 text-[11px] font-medium text-slate-600">
            {tag}
          </span>
        ))
      }
    </div>

    {
      project.link && (
        <a
          href={project.link}
          target="_blank"
          rel="noopener noreferrer"
          class="bg-brand mt-8 inline-flex items-center gap-2 rounded-full px-5 py-2.5 text-sm font-semibold text-white shadow-md transition hover:shadow-lg"
        >
          {t("projects.visit")}
          <Icon name="arrow-up-right" class="h-4 w-4" />
        </a>
      )
    }

    <!-- Voltar -->
    <div class="mt-14 border-t border-slate-200 pt-8">
      <a
        href={projectsHref}
        class="inline-flex items-center gap-1.5 text-sm font-semibold text-slate-700 transition hover:text-violet-600"
      >
        <Icon name="arrow-up-right" class="h-4 w-4 rotate-[225deg]" />
        {t("projects.back")}
      </a>
    </div>
  </main>

  <Footer lang={lang} />
</Layout>
