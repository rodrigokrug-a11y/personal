---
interface Props {
  eyebrow: string;
  title: string;
  subtitle?: string;
  align?: "left" | "center";
}
const { eyebrow, title, subtitle, align = "left" } = Astro.props;
const isCenter = align === "center";
---

<div
  data-reveal
  class:list={[
    "max-w-2xl",
    isCenter && "mx-auto text-center",
  ]}
>
  <span
    class="inline-flex items-center gap-2 text-xs font-semibold uppercase tracking-[0.15em] text-accent-600 sm:tracking-[0.2em]"
  >
    <span class="bg-brand h-px w-6"></span>
    {eyebrow}
  </span>
  <h2 class="font-display mt-4 text-[1.75rem] font-bold leading-[1.15] tracking-tight text-slate-900 sm:text-[2.25rem] sm:leading-[1.1] lg:text-[2.75rem]">
    {title}
  </h2>
  {
    subtitle && (
      <p class="mt-4 text-base leading-relaxed text-slate-600 sm:mt-5 sm:text-lg">
        {subtitle}
      </p>
    )
  }
</div>
