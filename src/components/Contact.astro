---
import { personal, socials } from "../data/site";
import { useTranslations, type Lang } from "../i18n/ui";
import SectionHeading from "./SectionHeading.astro";
import Icon from "./Icon.astro";

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);

// 🔧 TODO: crie um formulário grátis em https://formspree.io e cole o ID aqui.
// Enquanto estiver "SEU_ID", o formulário cai no seu e-mail via mailto.
const FORMSPREE_ENDPOINT = "https://formspree.io/f/SEU_ID";
const formConfigured = !FORMSPREE_ENDPOINT.includes("SEU_ID");
const formAction = formConfigured
  ? FORMSPREE_ENDPOINT
  : `mailto:${personal.email}`;
---

<section id="contato" class="relative scroll-mt-20 py-24 sm:py-28">
  <div class="mx-auto max-w-6xl px-5">
    <div class="grid gap-12 lg:grid-cols-2 lg:gap-16">
      <!-- Texto + contatos -->
      <div>
        <SectionHeading
          eyebrow={t("contact.eyebrow")}
          title={t("contact.title")}
          subtitle={t("contact.subtitle")}
        />

        <div data-reveal data-reveal-delay="1" class="mt-8 space-y-4">
          <a
            href={`mailto:${personal.email}`}
            class="group flex items-center gap-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm transition hover:border-violet-300"
          >
            <span class="bg-brand grid h-11 w-11 place-items-center rounded-xl text-white">
              <Icon name="email" class="h-5 w-5" />
            </span>
            <span>
              <span class="block text-xs font-semibold uppercase tracking-wider text-slate-400"
                >{t("contact.email")}</span
              >
              <span class="block text-sm font-semibold text-slate-900">{personal.email}</span>
            </span>
          </a>

          <div>
            <p class="text-xs font-semibold uppercase tracking-wider text-slate-400">
              {t("contact.or")}
            </p>
            <div class="mt-3 flex gap-3">
              {
                socials.map((s) => (
                  <a
                    href={s.href}
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label={s.label}
                    class="grid h-11 w-11 place-items-center rounded-xl border border-slate-200 bg-white text-slate-600 shadow-sm transition hover:-translate-y-0.5 hover:border-violet-300 hover:text-violet-600"
                  >
                    <Icon name={s.icon} class="h-5 w-5" />
                  </a>
                ))
              }
            </div>
          </div>
        </div>
      </div>

      <!-- Formulário -->
      <form
        data-reveal
        data-reveal-delay="2"
        action={formAction}
        method="POST"
        class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm sm:p-8"
      >
        <div class="grid gap-4">
          <label class="block">
            <span class="text-sm font-semibold text-slate-700">{t("form.name")}</span>
            <input
              type="text"
              name="name"
              required
              placeholder={t("form.placeholder.name")}
              class="mt-1.5 w-full rounded-xl border border-slate-300 bg-slate-50 px-4 py-3 text-sm text-slate-900 outline-none transition placeholder:text-slate-400 focus:border-violet-400 focus:bg-white focus:ring-2 focus:ring-violet-200"
            />
          </label>
          <label class="block">
            <span class="text-sm font-semibold text-slate-700">{t("form.email")}</span>
            <input
              type="email"
              name="email"
              required
              placeholder={t("form.placeholder.email")}
              class="mt-1.5 w-full rounded-xl border border-slate-300 bg-slate-50 px-4 py-3 text-sm text-slate-900 outline-none transition placeholder:text-slate-400 focus:border-violet-400 focus:bg-white focus:ring-2 focus:ring-violet-200"
            />
          </label>
          <label class="block">
            <span class="text-sm font-semibold text-slate-700">{t("form.message")}</span>
            <textarea
              name="message"
              rows="4"
              required
              placeholder={t("form.placeholder.message")}
              class="mt-1.5 w-full resize-y rounded-xl border border-slate-300 bg-slate-50 px-4 py-3 text-sm text-slate-900 outline-none transition placeholder:text-slate-400 focus:border-violet-400 focus:bg-white focus:ring-2 focus:ring-violet-200"
            ></textarea>
          </label>
          <button
            type="submit"
            class="bg-brand mt-1 inline-flex items-center justify-center gap-2 rounded-xl px-6 py-3.5 text-sm font-semibold text-white shadow-lg shadow-violet-500/25 transition hover:opacity-90"
          >
            {t("form.send")}
            <Icon name="arrow" class="h-4 w-4" />
          </button>
        </div>
      </form>
    </div>
  </div>
</section>
