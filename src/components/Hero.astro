---
import { personal } from "../data/site";
import { useTranslations, type Lang } from "../i18n/ui";
import Icon from "./Icon.astro";

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section id="top" class="relative overflow-hidden">
  <!-- Fundo mesh + grid sutil -->
  <div class="mesh-bg pointer-events-none absolute inset-0 -z-10"></div>
  <div
    class="pointer-events-none absolute inset-0 -z-10 opacity-[0.04]"
    style="background-image:linear-gradient(#0f172a 1px,transparent 1px),linear-gradient(90deg,#0f172a 1px,transparent 1px);background-size:56px 56px;"
  >
  </div>

  <div class="mx-auto max-w-6xl px-5 pt-36 pb-20 sm:pt-44 sm:pb-28">
    <div class="grid items-center gap-12 lg:grid-cols-[1.15fr_0.85fr]">
      <!-- Coluna de texto -->
      <div data-reveal>
        <span
          class="inline-flex items-center gap-2 rounded-full border border-violet-200 bg-violet-50/70 px-3 py-1.5 text-xs font-semibold text-violet-700"
        >
          <span class="relative flex h-2 w-2">
            <span
              class="absolute inline-flex h-full w-full animate-ping rounded-full bg-emerald-400 opacity-75"
            ></span>
            <span class="relative inline-flex h-2 w-2 rounded-full bg-emerald-500"></span>
          </span>
          {t("hero.eyebrow")}
        </span>

        <h1
          class="font-display mt-6 text-4xl font-bold leading-[1.05] tracking-tight text-slate-900 sm:text-5xl lg:text-6xl"
        >
          {personal.name}
          <span class="mt-2 block text-gradient">{personal.headline[lang]}</span>
        </h1>

        <p class="mt-4 text-sm font-semibold uppercase tracking-wider text-slate-500">
          {personal.role[lang]}
        </p>

        <p class="mt-6 max-w-xl text-base leading-relaxed text-slate-600 sm:text-lg">
          {personal.intro[lang]}
        </p>

        <div class="mt-9 flex flex-wrap items-center gap-3">
          <a
            href="#projetos"
            class="bg-brand group inline-flex items-center gap-2 rounded-xl px-6 py-3.5 text-sm font-semibold text-white shadow-lg shadow-violet-500/25 transition hover:opacity-90"
          >
            {t("hero.cta.primary")}
            <Icon name="arrow" class="h-4 w-4 transition group-hover:translate-x-0.5" />
          </a>
          <a
            href="#contato"
            class="inline-flex items-center gap-2 rounded-xl border border-slate-300 bg-white/70 px-6 py-3.5 text-sm font-semibold text-slate-800 transition hover:border-slate-400 hover:bg-white"
          >
            {t("hero.cta.secondary")}
          </a>
        </div>

        <p class="mt-6 text-sm text-slate-500">{personal.location[lang]}</p>
      </div>

      <!-- Coluna da foto -->
      <div data-reveal data-reveal-delay="2" class="relative mx-auto w-full max-w-sm">
        <!-- Blobs decorativos -->
        <div
          class="bg-brand animate-float absolute -left-6 -top-6 h-24 w-24 rounded-3xl opacity-80 blur-2xl"
        ></div>
        <div
          class="animate-float-slow absolute -bottom-8 -right-6 h-32 w-32 rounded-full opacity-70 blur-2xl"
          style="background-image:linear-gradient(45deg,#38bdf8,#67e8f9)"
        ></div>

        <!-- Moldura com anel em gradiente -->
        <div class="ring-brand relative rounded-[2rem] p-[3px] shadow-2xl shadow-violet-500/20">
          <div class="overflow-hidden rounded-[1.85rem] bg-white">
            <img
              src={personal.portrait}
              alt={personal.name}
              width="480"
              height="560"
              class="aspect-[4/5] w-full object-cover"
            />
          </div>

          <!-- Cartão flutuante -->
          <div
            class="glass animate-float-slow absolute -bottom-5 left-1/2 flex -translate-x-1/2 items-center gap-3 rounded-2xl border border-white/70 px-4 py-3 shadow-xl"
          >
            <span class="bg-brand grid h-9 w-9 place-items-center rounded-lg text-white">
              <Icon name="check" class="h-4 w-4" />
            </span>
            <div class="leading-tight">
              <p class="text-sm font-bold text-slate-900">{personal.stats[0].value}</p>
              <p class="text-[11px] text-slate-500">{personal.stats[0].label[lang]}</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
