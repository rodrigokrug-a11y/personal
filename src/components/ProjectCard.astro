---
import { type Project } from "../data/site";
import { useTranslations, type Lang } from "../i18n/ui";
import Icon from "./Icon.astro";

interface Props {
  project: Project;
  lang: Lang;
  delay?: number;
}
const { project, lang, delay = 0 } = Astro.props;
const t = useTranslations(lang);
const detailHref =
  lang === "pt" ? `/projetos/${project.slug}` : `/en/projects/${project.slug}`;
---

<article
  data-reveal
  data-reveal-delay={delay}
  class="group relative flex flex-col overflow-hidden rounded-3xl border border-slate-200 bg-white shadow-sm transition duration-300 hover:-translate-y-1 hover:shadow-2xl hover:shadow-accent-500/10"
>
  <!-- Cabeçalho visual: imagem OU gradiente com iniciais -->
  <div class="relative aspect-[16/10] overflow-hidden" style={`background-image:${project.gradient}`}>
    {
      project.image ? (
        <img
          src={project.image}
          alt={project.name}
          loading="lazy"
          class="h-full w-full object-cover transition duration-500 group-hover:scale-105"
        />
      ) : (
        <div class="absolute inset-0 grid place-items-center">
          <span class="font-display text-6xl font-bold text-white/90 drop-shadow-sm">
            {project.name.charAt(0)}
          </span>
          <div
            class="absolute inset-0 opacity-20"
            style="background-image:radial-gradient(circle at 20% 20%, white 1px, transparent 1px);background-size:22px 22px;"
          />
        </div>
      )
    }

    {
      project.featured && (
        <span class="absolute left-4 top-4 rounded-full bg-white/90 px-2.5 py-1 text-[11px] font-semibold text-accent-700 shadow-sm backdrop-blur">
          ★ {t("projects.featured")}
        </span>
      )
    }
    <span
      class="absolute right-4 top-4 rounded-full bg-black/25 px-2.5 py-1 text-[11px] font-medium text-white backdrop-blur"
    >
      {project.year}
    </span>
  </div>

  <!-- Conteúdo -->
  <div class="flex flex-1 flex-col p-6">
    <h3 class="font-display text-xl font-bold tracking-tight text-slate-900">{project.name}</h3>
    <p class="mt-1 text-sm font-medium text-accent-600">{project.tagline[lang]}</p>
    <p class="mt-3 text-sm leading-relaxed text-slate-600">{project.description[lang]}</p>

    <!-- Papel -->
    <p class="mt-4 text-xs text-slate-500">
      <span class="font-semibold uppercase tracking-wider text-slate-400">{t("projects.role")}:</span>
      {project.role[lang]}
    </p>

    <!-- Métricas -->
    {
      project.metrics.length > 0 && (
        <dl class="mt-4 grid grid-cols-2 gap-3">
          {project.metrics.map((m) => (
            <div class="rounded-xl bg-slate-50 px-3 py-2">
              <dt class="font-display text-lg font-bold text-slate-900">{m.value}</dt>
              <dd class="text-[11px] leading-tight text-slate-500">{m.label[lang]}</dd>
            </div>
          ))}
        </dl>
      )
    }

    <!-- Tags -->
    <div class="mt-5 flex flex-wrap gap-2">
      {
        project.tags.map((tag) => (
          <span class="rounded-full border border-slate-200 bg-white px-2.5 py-1 text-[11px] font-medium text-slate-600">
            {tag}
          </span>
        ))
      }
    </div>

    <!-- Ações -->
    <div class="mt-6 flex items-center gap-4 pt-2">
      <span
        class="inline-flex items-center gap-1.5 text-sm font-semibold text-slate-900 transition group-hover:text-accent-600"
      >
        {t("projects.details")}
        <Icon
          name="arrow-up-right"
          class="h-4 w-4 transition group-hover:translate-x-0.5 group-hover:-translate-y-0.5"
        />
      </span>
      {
        project.link && (
          <a
            href={project.link}
            target="_blank"
            rel="noopener noreferrer"
            class="relative z-20 inline-flex items-center gap-1 text-xs font-medium text-slate-400 transition hover:text-accent-600"
          >
            {t("projects.visit")}
          </a>
        )
      }
    </div>
  </div>

  <!-- Link que cobre o cartão inteiro (leva à página do projeto) -->
  <a href={detailHref} class="absolute inset-0 z-10" aria-label={project.name}></a>
</article>
