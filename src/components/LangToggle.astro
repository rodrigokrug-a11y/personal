---
import type { Lang } from "../i18n/ui";
import { localizedHome } from "../i18n/ui";

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const other: Lang = lang === "pt" ? "en" : "pt";
const href = localizedHome(other);
const labels: Record<Lang, string> = { pt: "PT", en: "EN" };
---

<a
  href={href}
  aria-label={lang === "pt" ? "Switch to English" : "Mudar para Português"}
  class="group inline-flex items-center gap-1 rounded-full border border-slate-200 bg-white/60 px-1 py-1 text-xs font-semibold text-slate-500 transition hover:border-violet-300"
>
  <span
    class:list={[
      "rounded-full px-2.5 py-1 transition",
      lang === "pt" ? "bg-brand text-white shadow-sm" : "group-hover:text-slate-900",
    ]}>PT</span
  >
  <span
    class:list={[
      "rounded-full px-2.5 py-1 transition",
      lang === "en" ? "bg-brand text-white shadow-sm" : "group-hover:text-slate-900",
    ]}>EN</span
  >
</a>
