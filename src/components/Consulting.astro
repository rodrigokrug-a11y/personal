---
import { services } from "../data/site";
import { useTranslations, type Lang } from "../i18n/ui";
import SectionHeading from "./SectionHeading.astro";
import Icon from "./Icon.astro";

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section id="consultoria" class="relative scroll-mt-20 bg-slate-50 py-24 sm:py-28">
  <div class="mx-auto max-w-6xl px-5">
    <SectionHeading
      eyebrow={t("consulting.eyebrow")}
      title={t("consulting.title")}
      subtitle={t("consulting.subtitle")}
    />

    <!-- Cartões de serviço -->
    <div class="mt-14 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {
        services.map((service, i) => (
          <div
            data-reveal
            data-reveal-delay={(i % 4) + 1}
            class="group rounded-3xl border border-slate-200 bg-white p-6 shadow-sm transition duration-300 hover:-translate-y-1 hover:shadow-xl hover:shadow-accent-500/10"
          >
            <span class="bg-brand inline-grid h-12 w-12 place-items-center rounded-2xl text-white shadow-sm">
              <Icon name={service.icon} class="h-6 w-6" />
            </span>
            <h3 class="font-display mt-5 text-lg font-bold text-slate-900">{service.title[lang]}</h3>
            <p class="mt-2 text-sm leading-relaxed text-slate-600">{service.description[lang]}</p>
          </div>
        ))
      }
    </div>

    <!-- Faixa de chamada para ação -->
    <div
      data-reveal
      class="bg-brand relative mt-14 overflow-hidden rounded-3xl px-8 py-12 text-center shadow-xl shadow-accent-500/25 sm:px-12 sm:py-14"
    >
      <div
        class="pointer-events-none absolute inset-0 opacity-15"
        style="background-image:radial-gradient(circle at 30% 20%, white 1.5px, transparent 1.5px);background-size:28px 28px;"
      >
      </div>
      <div class="relative mx-auto max-w-2xl">
        <h3 class="font-display text-2xl font-bold text-white sm:text-3xl">
          {t("consulting.cta.title")}
        </h3>
        <p class="mt-3 text-base leading-relaxed text-white/85">{t("consulting.cta.text")}</p>
        <a
          href="#contato"
          class="mt-7 inline-flex items-center gap-2 rounded-xl bg-white px-6 py-3.5 text-sm font-semibold text-accent-700 shadow-sm transition hover:bg-slate-100"
        >
          {t("consulting.cta.button")}
          <Icon name="arrow" class="h-4 w-4" />
        </a>
      </div>
    </div>
  </div>
</section>
