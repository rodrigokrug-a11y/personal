---
import { experiences, education, skillGroups, personal } from "../data/site";
import { useTranslations, type Lang } from "../i18n/ui";
import SectionHeading from "./SectionHeading.astro";
import Icon from "./Icon.astro";

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section id="experiencia" class="relative scroll-mt-20 py-24 sm:py-28">
  <div class="mx-auto max-w-6xl px-5">
    <SectionHeading
      eyebrow={t("experience.eyebrow")}
      title={t("experience.title")}
      subtitle={t("experience.subtitle")}
    />

    <div class="mt-14 grid gap-12 lg:grid-cols-[1.4fr_1fr]">
      <!-- Linha do tempo -->
      <div data-reveal>
        <ol class="relative border-l border-slate-200">
          {
            experiences.map((exp) => (
              <li class="mb-10 ml-6 last:mb-0">
                <span class="bg-brand absolute -left-[7px] mt-1.5 h-3.5 w-3.5 rounded-full ring-4 ring-white" />
                <div class="flex flex-wrap items-baseline justify-between gap-x-3">
                  <h3 class="font-display text-lg font-bold text-slate-900">{exp.role[lang]}</h3>
                  <span class="text-xs font-semibold text-violet-600">{exp.period[lang]}</span>
                </div>
                <p class="text-sm font-medium text-slate-700">
                  {exp.company}
                  <span class="text-slate-400"> · {exp.location[lang]}</span>
                </p>
                <p class="mt-2 text-sm leading-relaxed text-slate-600">{exp.description[lang]}</p>
                {exp.achievements.length > 0 && (
                  <ul class="mt-3 space-y-1.5">
                    {exp.achievements.map((a) => (
                      <li class="flex gap-2 text-sm text-slate-600">
                        <Icon name="check" class="mt-0.5 h-4 w-4 shrink-0 text-violet-500" />
                        <span>{a[lang]}</span>
                      </li>
                    ))}
                  </ul>
                )}
              </li>
            ))
          }
        </ol>

        <a
          href={lang === "en" ? personal.resumeUrlEn : personal.resumeUrl}
          download
          class="mt-4 inline-flex items-center gap-2 rounded-xl border border-slate-300 bg-white px-5 py-3 text-sm font-semibold text-slate-800 transition hover:border-slate-400 hover:bg-slate-50"
        >
          <Icon name="download" class="h-4 w-4" />
          {t("experience.download")}
        </a>
      </div>

      <!-- Competências + Formação -->
      <div data-reveal data-reveal-delay="1" class="space-y-8">
        <div>
          <h3 class="font-display text-lg font-bold text-slate-900">{t("experience.skills")}</h3>
          <div class="mt-4 space-y-5">
            {
              skillGroups.map((group) => (
                <div>
                  <p class="text-xs font-semibold uppercase tracking-wider text-slate-400">
                    {group.title[lang]}
                  </p>
                  <div class="mt-2 flex flex-wrap gap-2">
                    {group.items.map((item) => (
                      <span class="rounded-lg border border-slate-200 bg-slate-50 px-3 py-1.5 text-sm font-medium text-slate-700">
                        {item[lang]}
                      </span>
                    ))}
                  </div>
                </div>
              ))
            }
          </div>
        </div>

        <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
          <h3 class="font-display text-lg font-bold text-slate-900">{t("experience.education")}</h3>
          <ul class="mt-3 space-y-3">
            {
              education.map((edu) => (
                <li>
                  <p class="text-sm font-semibold text-slate-800">{edu.degree[lang]}</p>
                  <p class="text-sm text-slate-500">
                    {edu.institution} · {edu.period}
                  </p>
                </li>
              ))
            }
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>
