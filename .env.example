# ============================================================================
#  Variáveis de ambiente (NÃO comite o arquivo .env real — só este .example)
# ============================================================================
#
#  Estas variáveis só são necessárias no MODO SERVIDOR (admin pela web).
#  Para editar localmente (npm run dev), você NÃO precisa de nada disso.
#
#  Elas são geradas automaticamente quando você acessa /keystatic no site
#  publicado e clica em "Login with GitHub" → "Create GitHub App".
#  Veja DEPLOY-VPS.md para o passo a passo.
# ----------------------------------------------------------------------------

# Conexão do Keystatic com o GitHub (geradas ao criar o GitHub App):
KEYSTATIC_GITHUB_CLIENT_ID=
KEYSTATIC_GITHUB_CLIENT_SECRET=
KEYSTATIC_SECRET=

# "slug" do GitHub App (também ativa o modo GitHub no keystatic.config.ts):
PUBLIC_KEYSTATIC_GITHUB_APP_SLUG=
