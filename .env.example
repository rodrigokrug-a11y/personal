# ============================================================================
#  Variáveis de ambiente (NÃO comite o arquivo .env real — só este .example)
# ============================================================================
#
#  Estas variáveis só são necessárias quando você ativar a EDIÇÃO PELA WEB
#  (login com GitHub no site publicado). Para editar localmente (npm run dev),
#  você NÃO precisa de nada disso.
#
#  Como obter: veja DEPLOY.md → "Ativar login com GitHub".
# ----------------------------------------------------------------------------

# Conexão do Keystatic com o GitHub (criadas ao conectar o app do Keystatic):
KEYSTATIC_GITHUB_CLIENT_ID=
KEYSTATIC_GITHUB_CLIENT_SECRET=
KEYSTATIC_SECRET=

# Repositório onde o conteúdo fica salvo (ex.: rodrigokrug/site-pessoal):
PUBLIC_KEYSTATIC_GITHUB_REPO=
